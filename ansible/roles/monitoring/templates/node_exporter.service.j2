[Unit]
Description=Prometheus Node Exporter
After=network.target

[Service]
User=prometheus
Group=prometheus
Type=simple
ExecStart=/usr/local/bin/node_exporter \
  --web.listen-address=":{{ node_exporter_port }}" \
  --collector.filesystem \
  --collector.cpu \
  --collector.meminfo \
  --collector.diskstats \
  --collector.netdev
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
