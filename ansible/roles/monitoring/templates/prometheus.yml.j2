global:
  scrape_interval: 15s
  evaluation_interval: 15s
  external_labels:
    environment: "{{ ansible_hostname }}"

alerting:
  alertmanagers:
    - static_configs:
        - targets: []

rule_files:
  - "/etc/prometheus/alerts/*.yml"

scrape_configs:
  - job_name: "prometheus"
    static_configs:
      - targets: ["localhost:{{ prometheus_port }}"]

  - job_name: "node_exporter"
    static_configs:
      - targets:
{% for host in groups['app_servers'] %}
          - "{{ hostvars[host]['ansible_host'] }}:{{ node_exporter_port }}"
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: instance
        regex: "([^:]+):.*"
        replacement: "$1"
